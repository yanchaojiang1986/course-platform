ANTHROPIC_API_KEY=your_api_key_here
PORT=3001

# Auth & Membership
# 生产环境建议保持 true；本地无数据库可先设为 false
AUTH_REQUIRED=true
JWT_SECRET=replace_with_a_long_random_secret
AUTH_COOKIE_NAME=cp_session
SESSION_DAYS=30
BCRYPT_ROUNDS=10

# Local debug admin (仅本地/非生产环境自动生效)
LOCAL_ADMIN_ENABLED=true
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin12345
LOCAL_ADMIN_PLAN=svip

# Admin API key (用于生成授权码)
ADMIN_API_KEY=replace_with_admin_key

# PostgreSQL
# Zeabur 上通常会自动注入 DATABASE_URL
DATABASE_URL=postgres://user:pass@host:5432/dbname
